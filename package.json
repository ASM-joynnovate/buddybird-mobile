{
  "name": "buddybird-mobile",
  "main": "index.js",
  "version": "0.6.0",
  "scripts": {
    "start": "expo start",
    "start:dev": "APP_VARIANT=development expo start",
    "start:prod": "APP_VARIANT=production expo start",
    "reset-project": "node ./scripts/reset-project.js",
    "android": "expo run:android",
    "android:dev": "APP_VARIANT=development expo run:android",
    "android:prod": "APP_VARIANT=production expo run:android",
    "ios": "expo run:ios",
    "ios:dev": "APP_VARIANT=development expo run:ios",
    "ios:prod": "APP_VARIANT=production expo run:ios",
    "prebuild:dev": "APP_VARIANT=development expo prebuild --clean",
    "prebuild:prod": "APP_VARIANT=production expo prebuild --clean",
    "eas:build:dev:ios": "eas build --profile development --platform ios",
    "eas:build:dev:android": "eas build --profile development --platform android",
    "eas:build:dev:all": "eas build --profile development --platform all",
    "eas:build:preview:ios": "eas build --profile preview --platform ios",
    "eas:build:preview:android": "eas build --profile preview --platform android",
    "eas:build:preview:all": "eas build --profile preview --platform all",
    "eas:build:staging:ios": "eas build --profile staging --platform ios --non-interactive",
    "eas:build:staging:android": "eas build --profile staging --platform android --non-interactive",
    "eas:build:staging:all": "eas build --profile staging --platform android --non-interactive",
    "eas:submit:staging:all": "eas submit --profile staging --platform android --non-interactive --latest",
    "eas:build:prod:ios": "eas build --profile production --platform ios",
    "eas:build:prod:android": "eas build --profile production --platform android",
    "eas:build:prod:all": "eas build --profile production --platform all",
    "eas:build:local:dev:ios": "eas build --profile development --platform ios --local",
    "eas:build:local:dev:android": "eas build --profile development --platform android --local",
    "eas:build:local:preview:ios": "eas build --profile preview --platform ios --local",
    "eas:build:local:preview:android": "eas build --profile preview --platform android --local",
    "eas:build:local:prod:ios": "eas build --profile production --platform ios --local",
    "eas:build:local:prod:android": "eas build --profile production --platform android --local",
    "web": "expo start --web",
    "export": "expo export",
    "release:bump": "npm version --no-git-tag-version",
    "lint": "expo lint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@expo-google-fonts/fredoka": "^0.4.1",
    "@expo-google-fonts/nunito": "^0.4.2",
    "@expo/vector-icons": "^15.0.3",
    "@lodev09/react-native-true-sheet": "^3.11.0",
    "@microsoft/react-native-clarity": "^4.6.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-native-community/slider": "5.0.1",
    "@react-native-firebase/analytics": "^24.0.0",
    "@react-native-firebase/app": "^24.0.0",
    "@react-native-firebase/auth": "24.0.0",
    "@react-native-firebase/crashlytics": "^24.0.0",
    "@react-native-firebase/messaging": "^24.0.0",
    "@react-native-firebase/remote-config": "24.0.0",
    "@react-navigation/bottom-tabs": "^7.4.0",
    "@react-navigation/elements": "^2.9.18",
    "@react-navigation/native": "^7.1.8",
    "expo": "~54.0.35",
    "expo-application": "~7.0.0",
    "expo-asset": "~12.0.13",
    "expo-audio": "~1.1.1",
    "expo-build-properties": "~1.0.10",
    "expo-constants": "~18.0.13",
    "expo-crypto": "~15.0.9",
    "expo-dev-client": "~6.0.21",
    "expo-file-system": "~19.0.23",
    "expo-font": "~14.0.12",
    "expo-haptics": "~15.0.8",
    "expo-image": "~3.0.11",
    "expo-image-picker": "~17.0.11",
    "expo-keep-awake": "~15.0.8",
    "expo-linking": "~8.0.11",
    "expo-localization": "~17.0.9",
    "expo-router": "~6.0.24",
    "expo-splash-screen": "~31.0.13",
    "expo-status-bar": "~3.0.9",
    "expo-symbols": "~1.0.8",
    "expo-system-ui": "~6.0.9",
    "expo-tracking-transparency": "~6.0.0",
    "expo-updates": "~29.0.18",
    "expo-web-browser": "~15.0.10",
    "i18n-js": "^4.5.3",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-native": "0.81.5",
    "react-native-gesture-handler": "~2.28.0",
    "react-native-reanimated": "~4.1.1",
    "react-native-safe-area-context": "~5.6.0",
    "react-native-screens": "~4.16.0",
    "react-native-svg": "15.12.1",
    "react-native-web": "~0.21.0",
    "react-native-worklets": "0.5.1"
  },
  "devDependencies": {
    "@react-native-community/cli": "20.1.3",
    "@types/react": "~19.1.0",
    "eas-cli": "^20.1.0",
    "eslint": "^9.25.0",
    "eslint-config-expo": "~10.0.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "packageManager": "yarn@4.14.1"
}
